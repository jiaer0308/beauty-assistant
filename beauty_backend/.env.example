# Application Configuration
APP_NAME="Beauty Assistant API"
APP_VERSION="1.0.0"
DEBUG=true

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Model Configuration
MODEL_DIR=app/ml_engine/data
BISENET_MODEL_NAME=bisenet_resnet34.onnx

# Processing Configuration
MAX_FILE_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/jpg

# Performance Tuning
ENABLE_MODEL_CACHE=true
WORKERS=1

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
